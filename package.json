{
  "name": "relay",
  "version": "0.1.0",
  "description": "MCP-first multi-agent orchestration platform — spawn, coordinate, and cycle product/dev/test agents automatically",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "relay": "./bin/relay.mjs"
  },
  "scripts": {
    "dev": "tsup --watch",
    "dev:web": "pnpm --filter relay-web dev",
    "dev:api": "node dist/cli/index.js web",
    "build": "tsup && pnpm --filter relay-web build",
    "build:backend": "tsup",
    "build:frontend": "pnpm --filter relay-web build",
    "web": "pnpm build && node dist/cli/index.js web",
    "start": "node dist/cli/index.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent",
    "mcp",
    "orchestration",
    "claude-code",
    "cursor",
    "vibe-coding",
    "multi-agent"
  ],
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "playwright": "^1.50.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "vitest": "^4.1.2"
  }
}
