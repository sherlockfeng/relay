{
  "name": "ai-chat-digest",
  "version": "0.1.0",
  "description": "AI Chat Management Dashboard — Monitor, Digest, Recall your AI conversations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-chat-digest": "./bin/ai-chat-digest.mjs"
  },
  "scripts": {
    "dev": "tsup --watch & cd web && vite",
    "build": "tsup && cd web && vite build",
    "build:backend": "tsup",
    "build:frontend": "cd web && vite build",
    "start": "node dist/cli/index.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "chat",
    "cursor",
    "claude-code",
    "codex",
    "mcp",
    "dashboard"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "node-notifier": "^10.0.1",
    "openai": "^6.33.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/node-notifier": "^8.0.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "vitest": "^4.1.2"
  }
}
